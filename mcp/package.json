{
  "name": "otf-mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing the Ownership Token Framework (OTF) public read API as agent tools.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "otf",
    "ownership-token-framework",
    "crypto",
    "governance",
    "agent-tools"
  ],
  "homepage": "https://github.com/aragon/ownership-token-framework/tree/main/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aragon/ownership-token-framework.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/aragon/ownership-token-framework/issues"
  },
  "bin": {
    "otf-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:coverage": "npm run build && node --test --experimental-test-coverage test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
